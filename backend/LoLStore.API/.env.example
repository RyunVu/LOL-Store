# ======================
# JWT Authentication
# ======================
# 32+ byte cryptographically secure secret (Base64 or random string)
# Example generation:
#   openssl rand -base64 32
Jwt__Key=<<JWT_SECRET_MIN_32_BYTES>>
Jwt__Issuer=LoLStore
Jwt__Audience=LoLStore


# ======================
# Database
# ======================
# Example:
# Server=.\SQLEXPRESS;Database=LoLStore;Trusted_Connection=True;MultipleActiveResultSets=True;TrustServerCertificate=True
ConnectionStrings__DefaultConnection=<<SQL_SERVER_CONNECTION_STRING>>


# ======================
# Database Seeding
# ======================
# WARNING:
# Enable ONLY in Development or controlled environments
SEED_DATABASE=false

# Initial admin password used ONLY during seeding
# Must be strong and rotated after first login
INITIAL_ADMIN_PASSWORD=<<STRONG_ADMIN_PASSWORD>>


# ======================
# CORS
# ======================
AllowLocalHost=http://localhost:5173
